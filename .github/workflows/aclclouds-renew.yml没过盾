name: ACLClouds Auto Renew

on:
  schedule:
    - cron: '0 18 * * *'
  workflow_dispatch:

jobs:
  renew:
    runs-on: ubuntu-latest
    timeout-minutes: 20

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install Xray
        run: |
          # 写死稳定版本，避免 GitHub API 限流返回 302 导致版本号解析错误
          XRAY_VERSION="v25.3.6"
          echo "Installing Xray ${XRAY_VERSION}..."
          wget -q "https://github.com/XTLS/Xray-core/releases/download/${XRAY_VERSION}/Xray-linux-64.zip" -O xray.zip
          # 校验下载是否正常（正常的 zip 至少 5MB）
          SIZE=$(stat -c%s xray.zip)
          echo "Downloaded: ${SIZE} bytes"
          if [ "$SIZE" -lt 1048576 ]; then
            echo "ERROR: File too small, download likely failed:"
            head -3 xray.zip
            exit 1
          fi
          unzip -q xray.zip -d xray-bin
          chmod +x xray-bin/xray
          sudo mv xray-bin/xray /usr/local/bin/xray
          xray version

      - name: Configure and start Xray
        run: |
          python3 -c "
          import json, pathlib
          cfg = {
            'log': {'loglevel': 'warning'},
            'inbounds': [{'listen': '127.0.0.1', 'port': 1080, 'protocol': 'socks', 'settings': {'auth': 'noauth', 'udp': True}, 'tag': 'socks-in'}],
            'outbounds': [
              {
                'protocol': 'vless',
                'settings': {'vnext': [{'address': 'shopify.com', 'port': 2083, 'users': [{'id': '3f34622f-1199-4f2a-8c6b-72893ce3527e', 'encryption': 'none'}]}]},
                'streamSettings': {
                  'network': 'ws', 'security': 'tls',
                  'tlsSettings': {'serverName': '20.fnos9527.de5.net', 'allowInsecure': True},
                  'wsSettings': {'path': '/', 'headers': {'Host': '20.fnos9527.de5.net'}}
                },
                'tag': 'vless-out'
              },
              {'protocol': 'freedom', 'tag': 'direct'}
            ],
            'routing': {'rules': [{'type': 'field', 'inboundTag': ['socks-in'], 'outboundTag': 'vless-out'}]}
          }
          pathlib.Path('/tmp/xray-config.json').write_text(json.dumps(cfg))
          print('xray-config.json OK')
          "
          xray -config /tmp/xray-config.json > /tmp/xray.log 2>&1 &
          for i in $(seq 1 20); do
            nc -z 127.0.0.1 1080 2>/dev/null && echo "Xray ready" && break
            echo "Waiting $i/20..." && sleep 1
          done
          PROXY_IP=$(curl -s --socks5 127.0.0.1:1080 --max-time 20 https://api.ipify.org || echo "failed")
          echo "Proxy IP: $PROXY_IP"
          cat /tmp/xray.log || true

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install dependencies
        run: npm install playwright

      - name: Install Chromium
        run: npx playwright install chromium --with-deps

      - name: Run renewal script
        env:
          ACL_EMAIL:     ${{ secrets.ACL_EMAIL }}
          ACL_PASSWORD:  ${{ secrets.ACL_PASSWORD }}
          ACL_SERVER_ID: ${{ secrets.ACL_SERVER_ID }}
          TG_BOT_TOKEN:  ${{ secrets.TG_BOT_TOKEN }}
          TG_CHAT_ID:    ${{ secrets.TG_CHAT_ID }}
        run: node renew.mjs

      - name: Upload screenshots
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: screenshots
          path: |
            debug-login.png
            debug-server.png
            debug-after-renew.png
            error-screenshot.png
          if-no-files-found: ignore
          retention-days: 7
